# === Server-side only (never exposed to browser) ===
DATABASE_URL=postgresql://user:password@host:5432/database
SESSION_SECRET=generate-a-random-64-char-string-here
UPLOAD_DIR=./uploads

# === Public (safe to expose to browser, prefixed NEXT_PUBLIC_) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx

# === Production only ===
# NEXT_PUBLIC_SITE_URL=https://your-app.railway.app  # Required for Socket.io CORS in production
# PORT=3000  # Injected by Railway/AWS automatically
